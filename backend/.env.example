# Copy to .env and fill in real values.

# --- Database ---
# Async driver (asyncpg) is used by the app.
DATABASE_URL=postgresql+asyncpg://manero:manero@localhost:5432/manero
# Sync driver (psycopg) is used by Alembic migrations and the seed script.
SYNC_DATABASE_URL=postgresql+psycopg://manero:manero@localhost:5432/manero

# --- App ---
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173

# --- Admin auth ---
# Signs admin session tokens. Anyone who knows this can mint a valid admin
# token, so use a long random value and a DIFFERENT one in every environment.
# Generate:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# The app refuses to start with the default value when ENVIRONMENT=production.
JWT_SECRET=dev-only-insecure-jwt-secret-change-me
ACCESS_TOKEN_MINUTES=720

# --- Payments ---
# "dummy"    -> fake gateway, no account or keys needed. Development only.
# "razorpay" -> the real thing; fill in the keys below.
# Switching gateways is this one line; no code changes.
PAYMENT_PROVIDER=dummy

# Signs simulated dummy payments. Any string; only matters locally.
DUMMY_PAYMENT_SECRET=dummy-local-signing-secret

# Only needed when PAYMENT_PROVIDER=razorpay.
# Get these from https://dashboard.razorpay.com/app/keys with "Test Mode" toggled on.
# RAZORPAY_KEY_ID is sent to the browser; RAZORPAY_KEY_SECRET must never leave the server.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Shipping ---
# Flat shipping fee in paise (INR 49.00). Free above the threshold.
SHIPPING_FEE_PAISE=4900
FREE_SHIPPING_THRESHOLD_PAISE=59900
